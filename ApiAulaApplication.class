package com.educativo.apiaulapoo.exception;

/**
 * Excepción personalizada para cuando un recurso no es encontrado (404).
 * Se lanza cuando se intenta acceder a un usuario o producto que no existe.
 */
public class ResourceNotFoundException extends RuntimeException {
    
    public ResourceNotFoundException(String mensaje) {
        super(mensaje);
    }

    public ResourceNotFoundException(String mensaje, Throwable causa) {
        super(mensaje, causa);
    }
}
