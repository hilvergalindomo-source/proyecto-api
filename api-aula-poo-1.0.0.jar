package com.educativo.apiaulapoo.exception;

/**
 * Excepción personalizada para errores de validación (400).
 * Se lanza cuando los datos enviados no cumplen con las validaciones requeridas.
 */
public class BadRequestException extends RuntimeException {
    
    public BadRequestException(String mensaje) {
        super(mensaje);
    }

    public BadRequestException(String mensaje, Throwable causa) {
        super(mensaje, causa);
    }
}
